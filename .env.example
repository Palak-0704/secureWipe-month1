# Copy this file to .env and fill in real values.
# Do not commit .env.

GROQ_API_KEY=your_groq_api_key_here
GROQ_API_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
SECUREWIPE_CERT_SIGNING_SEED=replace_with_32_byte_hex_or_base64_seed

# Safety policy flags (defaults are safe when unset)
# Allow destructive flow even when detection confidence is unknown.
# Keep disabled for normal operation.
SECUREWIPE_ALLOW_UNKNOWN_DETECTION_CONFIDENCE=0

# Legacy alias for the same behavior (kept for compatibility).
SECUREWIPE_ALLOW_UNKNOWN_DETECTION=0

# Break-glass startup override for production safety checks.
# Keep disabled unless running controlled emergency debugging.
SECUREWIPE_ALLOW_UNSAFE_BOOT=0

# Bypass Administrator/root startup enforcement for local development only.
# Do NOT enable this in production or destructive wipe environments.
SECUREWIPE_ALLOW_UNPRIVILEGED_START=0

# Runtime binding and environment.
SECUREWIPE_ENV=development
SECUREWIPE_BIND_HOST=127.0.0.1
SECUREWIPE_BIND_PORT=8080

# Base directory for runtime-generated data: sessions, confirmations, results, and history.
# Defaults to ./data when unset.
SECUREWIPE_DATA_DIR=data

# CORS policy.
SECUREWIPE_CORS_ALLOW_ANY=0
SECUREWIPE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# High-risk endpoint guard controls.
SECUREWIPE_GUARD_MAX_BODY_BYTES=262144
SECUREWIPE_GUARD_RATE_LIMIT=20
SECUREWIPE_GUARD_RATE_WINDOW_SECONDS=60
SECUREWIPE_GUARD_TIMEOUT_SECONDS=30

# Optional absolute path to a prebuilt offline_runtime binary that should be
# copied into the USB handoff package during /api/usb/prepare.
SECUREWIPE_OFFLINE_RUNTIME_BINARY=

# USB provisioning mode:
# - simulation (default): generate handoff artifacts only
# - real: execute host-side provisioning command
SECUREWIPE_USB_PROVISION_MODE=simulation

# Require explicit overwrite confirmation text in real mode.
# When enabled, request body must include usb_overwrite_confirmation_text=ERASE_USB.
SECUREWIPE_USB_REQUIRE_OVERWRITE_CONFIRMATION=0

# Real provisioning command template used when SECUREWIPE_USB_PROVISION_MODE=real.
# Supports placeholders like {usb_path} and {manifest_path}.
SECUREWIPE_USB_REAL_PROVISION_COMMAND=

# Optional JSON array of args for real provisioning command.
# Supports placeholders: {usb_device_id}, {output_path}
SECUREWIPE_USB_REAL_PROVISION_ARGS_JSON=[]

# Additional gate for host-side real provisioning command execution.
# Keep disabled unless running controlled lab operations.
SECUREWIPE_USB_REAL_PROVISION_ENABLED=0

# Backward-compatible legacy aliases (prefer SECUREWIPE_USB_REAL_* names above).
# SECUREWIPE_USB_PROVISION_COMMAND=
# SECUREWIPE_USB_PROVISION_ARGS_JSON=[]

# Real USB provisioning is blocked by default even in real mode.
# Set to 1 only for controlled lab operations.
SECUREWIPE_USB_REAL_BREAKGLASS=0

# Comma-separated removable USB IDs that are explicitly permitted for real provisioning.
# Keep empty to deny all real USB writes by default.
SECUREWIPE_USB_REAL_ALLOWLIST=

# Minimum removable USB size (GB) accepted for preparation/provisioning.
SECUREWIPE_USB_MIN_SIZE_GB=8
